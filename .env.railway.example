# SKALER Backend - Railway

# Servidor
NODE_ENV=production
PORT=3000
API_URL=https://TU-BACKEND.railway.app

# Base de datos
# Usa UNA de estas dos opciones:
# 1. Pegar la URL completa que entrega Railway MySQL
DATABASE_URL=mysql://root:TU_PASSWORD@HOST:PUERTO/railway

# 2. O dejar que Railway inyecte MYSQLHOST, MYSQLPORT, MYSQLUSER,
# MYSQLPASSWORD y MYSQLDATABASE automaticamente

# Seguridad
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-unico
JWT_EXPIRE=24h

# Archivos
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Frontend y CORS
FRONTEND_URL=https://TU-FRONTEND.web.app
WEB_APP_URL=https://TU-FRONTEND.web.app
CORS_ORIGINS=https://TU-FRONTEND.web.app,https://TU-OTRO-FRONTEND.web.app

# Sesiones enlazadas app -> web
WEB_LAUNCH_TICKET_EXPIRE=30m
WEB_SESSION_EXPIRE=12h
APP_SESSION_HEARTBEAT_TTL=90s

# SSL para MySQL remoto si hace falta
DB_SSL=true