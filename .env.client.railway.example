# SKALER Backend - Railway del CLIENTE (no usar el entorno de desarrollo personal)
#
# Copia este archivo como referencia al crear variables en Railway Dashboard.
# NO subas contraseñas reales a Git.

# Servidor
NODE_ENV=production
PORT=3000
API_URL=https://backendapp-production-286f.up.railway.app

# Base de datos (MySQL en Railway)
# Opción A: pegar DATABASE_URL completa desde Railway MySQL
DATABASE_URL=mysql://root:TU_PASSWORD@HOST:PUERTO/railway

# Opción B: dejar que Railway inyecte MYSQLHOST, MYSQLPORT, MYSQLUSER,
# MYSQLPASSWORD y MYSQLDATABASE automáticamente al vincular el servicio MySQL

# Seguridad (genera uno nuevo por cliente)
JWT_SECRET=genera-un-secreto-largo-unico-para-este-cliente
JWT_EXPIRE=24h

# Archivos subidos (evidencias, firmas, etc.)
# Desarrollo local:
UPLOAD_DIR=./uploads
# Producción Railway — montar volumen en /data/uploads y usar:
# UPLOAD_DIR=/data/uploads
MAX_FILE_SIZE=10485760

# CORS (ajusta cuando tengas URL web del cliente)
# OBLIGATORIO para enlaces temporales app -> web (bridge_ticket)
WEB_APP_URL=https://skalerapp-web.web.app
FRONTEND_URL=https://skalerapp-web.web.app
CORS_ORIGINS=https://skalerapp-web.web.app

# Sesiones app -> web temporal
WEB_LAUNCH_TICKET_EXPIRE=30m
WEB_SESSION_EXPIRE=12h
APP_SESSION_HEARTBEAT_TTL=90s

# SSL MySQL remoto
DB_SSL=true

# Versionado app móvil / web (GET /api/app/version)
# Requiere backend desplegado con la ruta /api/app/version (commit reciente).
APP_VERSION_CHECK_ENABLED=true
APP_LATEST_VERSION=1.0.1
APP_MIN_VERSION=1.0.0
APP_LATEST_BUILD_NUMBER=2
APP_MIN_BUILD_NUMBER=1
# URL directa al .apk del release (obligatoria para botón "Descargar" en la app)
# Tras publicar release v1.0.1 con app-release.apk adjunto:
APP_ANDROID_DOWNLOAD_URL=https://github.com/skalerapp/skaler-app-updates/releases/download/v1.0.1/Skaler-1.0.1.apk
# Página de releases de GitHub (fallback si no hay APK directo)
APP_GITHUB_RELEASES_URL=https://github.com/skalerapp/skaler-app-updates/releases/latest
APP_RELEASE_NOTES=Asistencia admin/coordinador, auditoría, employee_id en asistencia, imágenes Railway y compatibilidad Android.
# Opcional; si falta, usa WEB_APP_URL
APP_WEB_URL=https://skalerapp-web.web.app
