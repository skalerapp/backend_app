{
  "name": "skaler-backend",
  "version": "1.0.0",
  "description": "Backend API for SKALER - Sistema Integral de Gestión Operativa Empresarial",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "db:rebuild:local": "node src/utils/rebuildDatabaseFromSchema.js",
    "db:reset:admin-only": "node src/utils/rebuildDatabaseFromSchema.js --admin-only",
    "db:schema:sync": "node src/utils/syncCurrentSchema.js",
    "db:schema:export": "node src/utils/exportCurrentSchema.js",
    "db:seed:demo": "node src/utils/seedOperationalDemoData.js",
    "migrate": "node src/utils/migrate.js",
    "migrate:audit:triggers": "node src/utils/installAuditTriggers.js",
      "verify:audit:triggers": "node src/utils/verifyAuditTriggers.js",
    "migrate:attendance:drop-status": "node src/utils/dropAttendanceStatusColumn.js",
    "migrate:activities:backfill-legacy": "node src/utils/backfillActivitiesLegacy.js",
    "migrate:users:roles:v1": "node src/utils/migrateUserRolesV1.js",
    "migrate:users:super-admin": "node src/utils/migrateSuperAdminUser.js",
    "assign:users:role": "node src/utils/assignRoleToUsersByEmail.js",
    "import:warehouse:assets": "node src/utils/importWarehouseAssetsCsv.js",
    "cleanup:test-data": "node src/utils/cleanupTestData.js",
    "reset:auto-increment": "node src/utils/resetAutoIncrement.js",
    "resequence:ids": "node src/utils/resequenceIds.js"
  },
  "keywords": [
    "skaler",
    "gestión",
    "empresarial",
    "operativo"
  ],
  "author": "JMS Tech",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "mysql2": "^3.2.0",
    "multer": "^1.4.5-lts.1",
    "morgan": "^1.10.0",
    "express-validator": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3"
  }
}
